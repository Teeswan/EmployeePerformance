@page "/appraisalforms/details/{Id:int}"
@inject EPMS.Blazor.Services.IAppraisalFormBlazorService AppraisalFormService
@inject NavigationManager NavigationManager

<h3>Appraisal Form Details</h3>

@if (form == null)
{
    <p><em>Loading...</em></p>
}
else
{
    <div>
        <hr />
        <dl class="row">
            <dt class="col-sm-2">Form ID</dt>
            <dd class="col-sm-10">@form.FormId</dd>

            <dt class="col-sm-2">Form Name</dt>
            <dd class="col-sm-10">@form.FormName</dd>

            <dt class="col-sm-2">Status</dt>
            <dd class="col-sm-10">@(form.IsActive == true ? "Active" : "Inactive")</dd>
        </dl>
    </div>
    <div>
        <a href="/appraisalforms/edit/@form.FormId" class="btn btn-warning">Edit</a>
        <a href="/appraisalforms" class="btn btn-secondary">Back to List</a>
    </div>
}

@code {
    [Parameter]
    public int Id { get; set; }

    private EPMS.Shared.DTOs.AppraisalFormDto? form;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            form = await AppraisalFormService.GetAppraisalFormByIdAsync(Id);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading appraisal form details: {ex.Message}");
        }
    }
}
