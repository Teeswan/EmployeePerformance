@page "/appraisalforms/edit/{Id:int}"
@using EPMS.Shared.Requests
@inject EPMS.Blazor.Services.IAppraisalFormBlazorService AppraisalFormService
@inject NavigationManager NavigationManager

<h3>Edit Appraisal Form</h3>

<hr />
@if (updateRequest == null)
{
    <p><em>Loading...</em></p>
}
else
{
    <div class="row">
        <div class="col-md-4">
            <EditForm Model="@updateRequest" OnValidSubmit="HandleValidSubmit">
                <DataAnnotationsValidator />
                <ValidationSummary />

                <div class="form-group mb-3">
                    <label for="formName" class="form-label">Form Name</label>
                    <InputText id="formName" class="form-control" @bind-Value="updateRequest.FormName" />
                </div>

                <div class="form-check mb-3">
                    <InputCheckbox id="isActive" class="form-check-input" @bind-Value="isActiveValue" />
                    <label for="isActive" class="form-check-label">Is Active</label>
                </div>

                <button type="submit" class="btn btn-primary">Save</button>
                <a href="/appraisalforms" class="btn btn-secondary">Cancel</a>
            </EditForm>
        </div>
    </div>
}

@code {
    [Parameter]
    public int Id { get; set; }

    private UpdateAppraisalFormRequest? updateRequest;
    private bool isActiveValue { get; set; }

    protected override async Task OnInitializedAsync()
    {
        var form = await AppraisalFormService.GetAppraisalFormByIdAsync(Id);
        if (form != null)
        {
            updateRequest = new UpdateAppraisalFormRequest
            {
                FormName = form.FormName,
                IsActive = form.IsActive
            };
            isActiveValue = form.IsActive ?? false;
        }
        else
        {
            NavigationManager.NavigateTo("/appraisalforms");
        }
    }

    private async Task HandleValidSubmit()
    {
        if (updateRequest != null)
        {
            updateRequest.IsActive = isActiveValue;
            try
            {
                await AppraisalFormService.UpdateAppraisalFormAsync(Id, updateRequest);
                NavigationManager.NavigateTo("/appraisalforms");
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Error updating appraisal form: {ex.Message}");
            }
        }
    }
}
