@page "/performanceoutcomes"
@inject EPMS.Blazor.Services.IPerformanceOutcomeBlazorService PerformanceOutcomeService
@inject NavigationManager NavigationManager

<h3>Performance Outcomes</h3>

<p>
    <a href="/performanceoutcomes/create" class="btn btn-primary">Create New</a>
</p>

@if (performanceOutcomes == null)
{
    <p><em>Loading...</em></p>
}
else
{
    <table class="table">
        <thead>
            <tr>
                <th>Outcome ID</th>
                <th>Employee ID</th>
                <th>Cycle ID</th>
                <th>Recommendation</th>
                <th>Status</th>
                <th>Effective Date</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var outcome in performanceOutcomes)
            {
                <tr>
                    <td>@outcome.OutcomeId</td>
                    <td>@outcome.EmployeeId</td>
                    <td>@outcome.CycleId</td>
                    <td>@outcome.RecommendationType</td>
                    <td>@outcome.ApprovalStatus</td>
                    <td>@outcome.EffectiveDate?.ToString("yyyy-MM-dd")</td>
                    <td>
                        <a href="/performanceoutcomes/details/@outcome.OutcomeId" class="btn btn-info btn-sm">Details</a>
                        <a href="/performanceoutcomes/edit/@outcome.OutcomeId" class="btn btn-warning btn-sm">Edit</a>
                        <button class="btn btn-danger btn-sm" @onclick="(() => DeletePerformanceOutcome(outcome.OutcomeId))">Delete</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private IEnumerable<EPMS.Shared.DTOs.PerformanceOutcomeDto>? performanceOutcomes;

    protected override async Task OnInitializedAsync()
    {
        await LoadPerformanceOutcomes();
    }

    private async Task LoadPerformanceOutcomes()
    {
        try
        {
            performanceOutcomes = await PerformanceOutcomeService.GetAllPerformanceOutcomesAsync();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading performance outcomes: {ex.Message}");
            performanceOutcomes = new List<EPMS.Shared.DTOs.PerformanceOutcomeDto>();
        }
    }

    private async Task DeletePerformanceOutcome(int outcomeId)
    {
        var confirmed = await JSRuntime.InvokeAsync<bool>("confirm", "Are you sure you want to delete this performance outcome?");
        if (confirmed)
        {
            var success = await PerformanceOutcomeService.DeletePerformanceOutcomeAsync(outcomeId);
            if (success)
            {
                await LoadPerformanceOutcomes();
            }
            else
            {
                Console.WriteLine("Error deleting performance outcome.");
            }
        }
    }

    [Inject]
    public IJSRuntime JSRuntime { get; set; } = default!;
}
