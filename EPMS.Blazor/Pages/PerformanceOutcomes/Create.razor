@page "/performanceoutcomes/create"
@using EPMS.Shared.Requests
@inject EPMS.Blazor.Services.IPerformanceOutcomeBlazorService PerformanceOutcomeService
@inject NavigationManager NavigationManager

<h3>Create Performance Outcome</h3>

<hr />
<div class="row">
    <div class="col-md-6">
        <EditForm Model="@createRequest" OnValidSubmit="HandleValidSubmit">
            <DataAnnotationsValidator />
            <ValidationSummary />

            <div class="form-group mb-3">
                <label for="employeeId" class="form-label">Employee ID</label>
                <InputNumber id="employeeId" class="form-control" @bind-Value="createRequest.EmployeeId" />
            </div>

            <div class="form-group mb-3">
                <label for="cycleId" class="form-label">Cycle ID</label>
                <InputNumber id="cycleId" class="form-control" @bind-Value="createRequest.CycleId" />
            </div>

            <div class="form-group mb-3">
                <label for="recommendationType" class="form-label">Recommendation Type</label>
                <InputText id="recommendationType" class="form-control" @bind-Value="createRequest.RecommendationType" />
            </div>

            <div class="form-group mb-3">
                <label for="oldPositionId" class="form-label">Old Position ID</label>
                <InputNumber id="oldPositionId" class="form-control" @bind-Value="createRequest.OldPositionId" />
            </div>

            <div class="form-group mb-3">
                <label for="newPositionId" class="form-label">New Position ID</label>
                <InputNumber id="newPositionId" class="form-control" @bind-Value="createRequest.NewPositionId" />
            </div>

            <div class="form-group mb-3">
                <label for="oldLevelId" class="form-label">Old Level ID</label>
                <InputText id="oldLevelId" class="form-control" @bind-Value="createRequest.OldLevelId" />
            </div>

            <div class="form-group mb-3">
                <label for="newLevelId" class="form-label">New Level ID</label>
                <InputText id="newLevelId" class="form-control" @bind-Value="createRequest.NewLevelId" />
            </div>

            <div class="form-group mb-3">
                <label for="approvalStatus" class="form-label">Approval Status</label>
                <InputText id="approvalStatus" class="form-control" @bind-Value="createRequest.ApprovalStatus" />
            </div>

            <div class="form-group mb-3">
                <label for="effectiveDate" class="form-label">Effective Date</label>
                <InputDate id="effectiveDate" class="form-control" @bind-Value="effectiveDateValue" />
            </div>

            <button type="submit" class="btn btn-primary">Create</button>
            <a href="/performanceoutcomes" class="btn btn-secondary">Cancel</a>
        </EditForm>
    </div>
</div>

@code {
    private CreatePerformanceOutcomeRequest createRequest = new();
    private DateTime? effectiveDateValue { get; set; }

    private async Task HandleValidSubmit()
    {
        if (effectiveDateValue.HasValue)
        {
            createRequest.EffectiveDate = DateOnly.FromDateTime(effectiveDateValue.Value);
        }
        try
        {
            await PerformanceOutcomeService.CreatePerformanceOutcomeAsync(createRequest);
            NavigationManager.NavigateTo("/performanceoutcomes");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error creating performance outcome: {ex.Message}");
        }
    }
}
