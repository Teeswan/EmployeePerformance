@page "/performanceoutcomes/details/{Id:int}"
@inject EPMS.Blazor.Services.IPerformanceOutcomeBlazorService PerformanceOutcomeService
@inject NavigationManager NavigationManager

<h3>Performance Outcome Details</h3>

@if (outcome == null)
{
    <p><em>Loading...</em></p>
}
else
{
    <div>
        <hr />
        <dl class="row">
            <dt class="col-sm-3">Outcome ID</dt>
            <dd class="col-sm-9">@outcome.OutcomeId</dd>

            <dt class="col-sm-3">Employee ID</dt>
            <dd class="col-sm-9">@outcome.EmployeeId</dd>

            <dt class="col-sm-3">Cycle ID</dt>
            <dd class="col-sm-9">@outcome.CycleId</dd>

            <dt class="col-sm-3">Recommendation Type</dt>
            <dd class="col-sm-9">@outcome.RecommendationType</dd>

            <dt class="col-sm-3">Old Position ID</dt>
            <dd class="col-sm-9">@outcome.OldPositionId</dd>

            <dt class="col-sm-3">New Position ID</dt>
            <dd class="col-sm-9">@outcome.NewPositionId</dd>

            <dt class="col-sm-3">Old Level ID</dt>
            <dd class="col-sm-9">@outcome.OldLevelId</dd>

            <dt class="col-sm-3">New Level ID</dt>
            <dd class="col-sm-9">@outcome.NewLevelId</dd>

            <dt class="col-sm-3">Approval Status</dt>
            <dd class="col-sm-9">@outcome.ApprovalStatus</dd>

            <dt class="col-sm-3">Effective Date</dt>
            <dd class="col-sm-9">@outcome.EffectiveDate?.ToString("yyyy-MM-dd")</dd>
        </dl>
    </div>
    <div>
        <a href="/performanceoutcomes/edit/@outcome.OutcomeId" class="btn btn-warning">Edit</a>
        <a href="/performanceoutcomes" class="btn btn-secondary">Back to List</a>
    </div>
}

@code {
    [Parameter]
    public int Id { get; set; }

    private EPMS.Shared.DTOs.PerformanceOutcomeDto? outcome;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            outcome = await PerformanceOutcomeService.GetPerformanceOutcomeByIdAsync(Id);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading performance outcome details: {ex.Message}");
        }
    }
}
