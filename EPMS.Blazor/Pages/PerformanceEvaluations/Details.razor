@page "/performanceevaluations/details/{Id:int}"
@inject EPMS.Blazor.Services.IPerformanceEvaluationBlazorService PerformanceEvaluationService
@inject NavigationManager NavigationManager

<h3>Performance Evaluation Details</h3>

@if (eval == null)
{
    <p><em>Loading...</em></p>
}
else
{
    <div>
        <hr />
        <dl class="row">
            <dt class="col-sm-3">Evaluation ID</dt>
            <dd class="col-sm-9">@eval.EvalId</dd>

            <dt class="col-sm-3">Employee ID</dt>
            <dd class="col-sm-9">@eval.EmployeeId</dd>

            <dt class="col-sm-3">Cycle ID</dt>
            <dd class="col-sm-9">@eval.CycleId</dd>

            <dt class="col-sm-3">Self Rating</dt>
            <dd class="col-sm-9">@eval.SelfRating</dd>

            <dt class="col-sm-3">Manager Rating</dt>
            <dd class="col-sm-9">@eval.ManagerRating</dd>

            <dt class="col-sm-3">Self Comments</dt>
            <dd class="col-sm-9">@eval.SelfComments</dd>

            <dt class="col-sm-3">Manager Comments</dt>
            <dd class="col-sm-9">@eval.ManagerComments</dd>

            <dt class="col-sm-3">Final Rating Score</dt>
            <dd class="col-sm-9">@eval.FinalRatingScore</dd>

            <dt class="col-sm-3">Finalized</dt>
            <dd class="col-sm-9">@(eval.IsFinalized == true ? "Yes" : "No")</dd>

            <dt class="col-sm-3">Finalized At</dt>
            <dd class="col-sm-9">@eval.FinalizedAt?.ToString("g")</dd>
        </dl>
    </div>
    <div>
        <a href="/performanceevaluations/edit/@eval.EvalId" class="btn btn-warning">Edit</a>
        <a href="/performanceevaluations" class="btn btn-secondary">Back to List</a>
    </div>
}

@code {
    [Parameter]
    public int Id { get; set; }

    private EPMS.Shared.DTOs.PerformanceEvaluationDto? eval;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            eval = await PerformanceEvaluationService.GetPerformanceEvaluationByIdAsync(Id);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading performance evaluation details: {ex.Message}");
        }
    }
}
