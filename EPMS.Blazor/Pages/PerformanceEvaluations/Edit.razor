@page "/performanceevaluations/edit/{Id:int}"
@using EPMS.Shared.Requests
@inject EPMS.Blazor.Services.IPerformanceEvaluationBlazorService PerformanceEvaluationService
@inject NavigationManager NavigationManager

<h3>Edit Performance Evaluation</h3>

<hr />
@if (updateRequest == null)
{
    <p><em>Loading...</em></p>
}
else
{
    <div class="row">
        <div class="col-md-6">
            <EditForm Model="@updateRequest" OnValidSubmit="HandleValidSubmit">
                <DataAnnotationsValidator />
                <ValidationSummary />

                <div class="form-group mb-3">
                    <label for="employeeId" class="form-label">Employee ID</label>
                    <InputNumber id="employeeId" class="form-control" @bind-Value="updateRequest.EmployeeId" />
                </div>

                <div class="form-group mb-3">
                    <label for="cycleId" class="form-label">Cycle ID</label>
                    <InputNumber id="cycleId" class="form-control" @bind-Value="updateRequest.CycleId" />
                </div>

                <div class="form-group mb-3">
                    <label for="selfRating" class="form-label">Self Rating</label>
                    <InputNumber id="selfRating" class="form-control" @bind-Value="updateRequest.SelfRating" />
                </div>

                <div class="form-group mb-3">
                    <label for="managerRating" class="form-label">Manager Rating</label>
                    <InputNumber id="managerRating" class="form-control" @bind-Value="updateRequest.ManagerRating" />
                </div>

                <div class="form-group mb-3">
                    <label for="selfComments" class="form-label">Self Comments</label>
                    <InputTextArea id="selfComments" class="form-control" @bind-Value="updateRequest.SelfComments" />
                </div>

                <div class="form-group mb-3">
                    <label for="managerComments" class="form-label">Manager Comments</label>
                    <InputTextArea id="managerComments" class="form-control" @bind-Value="updateRequest.ManagerComments" />
                </div>

                <div class="form-group mb-3">
                    <label for="finalRatingScore" class="form-label">Final Rating Score</label>
                    <InputNumber id="finalRatingScore" class="form-control" @bind-Value="updateRequest.FinalRatingScore" />
                </div>

                <div class="form-check mb-3">
                    <InputCheckbox id="isFinalized" class="form-check-input" @bind-Value="isFinalizedValue" />
                    <label for="isFinalized" class="form-check-label">Is Finalized</label>
                </div>

                <button type="submit" class="btn btn-primary">Save</button>
                <a href="/performanceevaluations" class="btn btn-secondary">Cancel</a>
            </EditForm>
        </div>
    </div>
}

@code {
    [Parameter]
    public int Id { get; set; }

    private UpdatePerformanceEvaluationRequest? updateRequest;
    private bool isFinalizedValue { get; set; }

    protected override async Task OnInitializedAsync()
    {
        var eval = await PerformanceEvaluationService.GetPerformanceEvaluationByIdAsync(Id);
        if (eval != null)
        {
            updateRequest = new UpdatePerformanceEvaluationRequest
            {
                EmployeeId = eval.EmployeeId,
                CycleId = eval.CycleId,
                SelfRating = eval.SelfRating,
                ManagerRating = eval.ManagerRating,
                SelfComments = eval.SelfComments,
                ManagerComments = eval.ManagerComments,
                FinalRatingScore = eval.FinalRatingScore,
                IsFinalized = eval.IsFinalized,
                FinalizedAt = eval.FinalizedAt
            };
            isFinalizedValue = eval.IsFinalized ?? false;
        }
        else
        {
            NavigationManager.NavigateTo("/performanceevaluations");
        }
    }

    private async Task HandleValidSubmit()
    {
        if (updateRequest != null)
        {
            updateRequest.IsFinalized = isFinalizedValue;
            if (isFinalizedValue && updateRequest.FinalizedAt == null)
            {
                updateRequest.FinalizedAt = DateTime.Now;
            }
            try
            {
                await PerformanceEvaluationService.UpdatePerformanceEvaluationAsync(Id, updateRequest);
                NavigationManager.NavigateTo("/performanceevaluations");
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Error updating performance evaluation: {ex.Message}");
            }
        }
    }
}
