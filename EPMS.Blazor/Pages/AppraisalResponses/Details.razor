@page "/appraisalresponses/details/{Id:long}"
@inject EPMS.Blazor.Services.IAppraisalResponseBlazorService AppraisalResponseService
@inject NavigationManager NavigationManager

<h3>Appraisal Response Details</h3>

@if (response == null)
{
    <p><em>Loading...</em></p>
}
else
{
    <div>
        <hr />
        <dl class="row">
            <dt class="col-sm-2">Response ID</dt>
            <dd class="col-sm-10">@response.ResponseId</dd>

            <dt class="col-sm-2">Evaluation ID</dt>
            <dd class="col-sm-10">@response.EvalId</dd>

            <dt class="col-sm-2">Question ID</dt>
            <dd class="col-sm-10">@response.QuestionId</dd>

            <dt class="col-sm-2">Respondent ID</dt>
            <dd class="col-sm-10">@response.RespondentId</dd>

            <dt class="col-sm-2">Answer Text</dt>
            <dd class="col-sm-10">@response.AnswerText</dd>

            <dt class="col-sm-2">Rating Value</dt>
            <dd class="col-sm-10">@response.RatingValue</dd>

            <dt class="col-sm-2">Anonymous</dt>
            <dd class="col-sm-10">@(response.IsAnonymous == true ? "Yes" : "No")</dd>
        </dl>
    </div>
    <div>
        <a href="/appraisalresponses/edit/@response.ResponseId" class="btn btn-warning">Edit</a>
        <a href="/appraisalresponses" class="btn btn-secondary">Back to List</a>
    </div>
}

@code {
    [Parameter]
    public long Id { get; set; }

    private EPMS.Shared.DTOs.AppraisalResponseDto? response;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            response = await AppraisalResponseService.GetAppraisalResponseByIdAsync((int)Id);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading appraisal response details: {ex.Message}");
        }
    }
}
