@page "/appraisalresponses/edit/{Id:long}"
@using EPMS.Shared.Requests
@inject EPMS.Blazor.Services.IAppraisalResponseBlazorService AppraisalResponseService
@inject NavigationManager NavigationManager

<h3>Edit Appraisal Response</h3>

<hr />
@if (updateRequest == null)
{
    <p><em>Loading...</em></p>
}
else
{
    <div class="row">
        <div class="col-md-6">
            <EditForm Model="@updateRequest" OnValidSubmit="HandleValidSubmit">
                <DataAnnotationsValidator />
                <ValidationSummary />

                <div class="form-group mb-3">
                    <label for="evalId" class="form-label">Evaluation ID</label>
                    <InputNumber id="evalId" class="form-control" @bind-Value="updateRequest.EvalId" />
                </div>

                <div class="form-group mb-3">
                    <label for="questionId" class="form-label">Question ID</label>
                    <InputNumber id="questionId" class="form-control" @bind-Value="updateRequest.QuestionId" />
                </div>

                <div class="form-group mb-3">
                    <label for="respondentId" class="form-label">Respondent ID</label>
                    <InputNumber id="respondentId" class="form-control" @bind-Value="updateRequest.RespondentId" />
                </div>

                <div class="form-group mb-3">
                    <label for="answerText" class="form-label">Answer Text</label>
                    <InputTextArea id="answerText" class="form-control" @bind-Value="updateRequest.AnswerText" />
                </div>

                <div class="form-group mb-3">
                    <label for="ratingValue" class="form-label">Rating Value</label>
                    <InputNumber id="ratingValue" class="form-control" @bind-Value="updateRequest.RatingValue" />
                </div>

                <div class="form-check mb-3">
                    <InputCheckbox id="isAnonymous" class="form-check-input" @bind-Value="isAnonymousValue" />
                    <label for="isAnonymous" class="form-check-label">Is Anonymous</label>
                </div>

                <button type="submit" class="btn btn-primary">Save</button>
                <a href="/appraisalresponses" class="btn btn-secondary">Cancel</a>
            </EditForm>
        </div>
    </div>
}

@code {
    [Parameter]
    public long Id { get; set; }

    private UpdateAppraisalResponseRequest? updateRequest;
    private bool isAnonymousValue { get; set; }

    protected override async Task OnInitializedAsync()
    {
        var response = await AppraisalResponseService.GetAppraisalResponseByIdAsync((int)Id);
        if (response != null)
        {
            updateRequest = new UpdateAppraisalResponseRequest
            {
                EvalId = response.EvalId,
                QuestionId = response.QuestionId,
                RespondentId = response.RespondentId,
                AnswerText = response.AnswerText,
                RatingValue = response.RatingValue,
                IsAnonymous = response.IsAnonymous
            };
            isAnonymousValue = response.IsAnonymous ?? false;
        }
        else
        {
            NavigationManager.NavigateTo("/appraisalresponses");
        }
    }

    private async Task HandleValidSubmit()
    {
        if (updateRequest != null)
        {
            updateRequest.IsAnonymous = isAnonymousValue;
            try
            {
                await AppraisalResponseService.UpdateAppraisalResponseAsync((int)Id, updateRequest);
                NavigationManager.NavigateTo("/appraisalresponses");
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Error updating appraisal response: {ex.Message}");
            }
        }
    }
}
