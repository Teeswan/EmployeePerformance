@page "/appraisalquestions/edit/{Id:int}"
@using EPMS.Shared.Requests
@inject EPMS.Blazor.Services.IAppraisalQuestionBlazorService AppraisalQuestionService
@inject NavigationManager NavigationManager

<h3>Edit Appraisal Question</h3>

<hr />
@if (updateRequest == null)
{
    <p><em>Loading...</em></p>
}
else
{
    <div class="row">
        <div class="col-md-6">
            <EditForm Model="@updateRequest" OnValidSubmit="HandleValidSubmit">
                <DataAnnotationsValidator />
                <ValidationSummary />

                <div class="form-group mb-3">
                    <label for="questionText" class="form-label">Question Text</label>
                    <InputTextArea id="questionText" class="form-control" @bind-Value="updateRequest.QuestionText" />
                </div>

                <div class="form-group mb-3">
                    <label for="category" class="form-label">Category</label>
                    <InputText id="category" class="form-control" @bind-Value="updateRequest.Category" />
                </div>

                <div class="form-check mb-3">
                    <InputCheckbox id="isRequired" class="form-check-input" @bind-Value="isRequiredValue" />
                    <label for="isRequired" class="form-check-label">Is Required</label>
                </div>

                <button type="submit" class="btn btn-primary">Save</button>
                <a href="/appraisalquestions" class="btn btn-secondary">Cancel</a>
            </EditForm>
        </div>
    </div>
}

@code {
    [Parameter]
    public int Id { get; set; }

    private UpdateAppraisalQuestionRequest? updateRequest;
    private bool isRequiredValue { get; set; }

    protected override async Task OnInitializedAsync()
    {
        var question = await AppraisalQuestionService.GetAppraisalQuestionByIdAsync(Id);
        if (question != null)
        {
            updateRequest = new UpdateAppraisalQuestionRequest
            {
                QuestionText = question.QuestionText,
                Category = question.Category,
                IsRequired = question.IsRequired
            };
            isRequiredValue = question.IsRequired ?? false;
        }
        else
        {
            NavigationManager.NavigateTo("/appraisalquestions");
        }
    }

    private async Task HandleValidSubmit()
    {
        if (updateRequest != null)
        {
            updateRequest.IsRequired = isRequiredValue;
            try
            {
                await AppraisalQuestionService.UpdateAppraisalQuestionAsync(Id, updateRequest);
                NavigationManager.NavigateTo("/appraisalquestions");
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Error updating appraisal question: {ex.Message}");
            }
        }
    }
}
