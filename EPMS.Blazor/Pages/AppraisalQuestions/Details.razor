@page "/appraisalquestions/details/{Id:int}"
@inject EPMS.Blazor.Services.IAppraisalQuestionBlazorService AppraisalQuestionService
@inject NavigationManager NavigationManager

<h3>Appraisal Question Details</h3>

@if (question == null)
{
    <p><em>Loading...</em></p>
}
else
{
    <div>
        <hr />
        <dl class="row">
            <dt class="col-sm-2">Question ID</dt>
            <dd class="col-sm-10">@question.QuestionId</dd>

            <dt class="col-sm-2">Question Text</dt>
            <dd class="col-sm-10">@question.QuestionText</dd>

            <dt class="col-sm-2">Category</dt>
            <dd class="col-sm-10">@question.Category</dd>

            <dt class="col-sm-2">Required</dt>
            <dd class="col-sm-10">@(question.IsRequired == true ? "Yes" : "No")</dd>
        </dl>
    </div>
    <div>
        <a href="/appraisalquestions/edit/@question.QuestionId" class="btn btn-warning">Edit</a>
        <a href="/appraisalquestions" class="btn btn-secondary">Back to List</a>
    </div>
}

@code {
    [Parameter]
    public int Id { get; set; }

    private EPMS.Shared.DTOs.AppraisalQuestionDto? question;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            question = await AppraisalQuestionService.GetAppraisalQuestionByIdAsync(Id);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading appraisal question details: {ex.Message}");
        }
    }
}
